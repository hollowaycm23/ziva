# Environment Overrides for Falcon Node (Gabrielle)
# Used by docker-compose via env_file or manual export

# Identity
ZIVA_NODE_NAME=gabrielle
ZIVA_NODE_TYPE=worker

# Model Divergence (DeepSeek-R1 for Logic/Consensus)
# Ensure this model is pulled on the remote: ollama pull deepseek-r1
ZIVA_MODEL=deepseek-r1:latest

# Hive Mind
ZIVA_MASTER_NODE=http://holloway.local:8000
