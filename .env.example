# Ziva Environment Configuration
# Copy this file to .env and fill in your values

# LLM Provider
ZIVA_LLM_BACKEND=lm_studio
ZIVA_LLM_BASE_URL=http://host.docker.internal:1234/v1
ZIVA_LLM_MODEL=qwen3-14b
ZIVA_LLM_KEY=your_lm_studio_api_key_here

# Model Name Override
MODEL_NAME=qwen3-14b

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_VECTOR_SIZE=768

# Browser Automation
PLAYWRIGHT_WS_ENDPOINT=ws://localhost:3000

# SearXNG
SEARXNG_SECRET_KEY=change_this_to_a_random_secret

# Open WebUI
OPENAI_API_KEY=change_this_to_a_random_key
WEBUI_SECRET_KEY=change_this_to_a_random_key

# Letta Database
LETTA_DB_USER=letta_user
LETTA_DB_PASSWORD=change_this_to_a_strong_password
LETTA_DB_NAME=lettadb

# Pi-hole (optional)
PIHOLE_WEBPASSWORD=change_this_to_a_strong_password

# Security
HASH_SALT=change_this_to_a_random_string

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Paths
ZIVA_DB_PATH=/app/data/ziva.db
ZIVA_BACKUP_DIR=/app/backups/sessions
ZIVA_OUTBOX_DIR=/app/outbox
ZIVA_LOG_DIR=/app/logs
ZIVA_PROFILE_PATH=/app/perfil.txt
ZIVA_COMPACT_PROFILE_PATH=/app/perfil_compact.txt
ZIVA_REQUIREMENTS_PATH=/app/requirements.txt
