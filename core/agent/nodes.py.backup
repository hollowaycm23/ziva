    """
    Checks if the generated answer is a refusal ("I don't know").
    """
    print("---VALIDATE ANSWER---")
    generation = state["generation"]
    
    # Simple heuristic to start (save LLM call)
    # Simple heuristic to start (save LLM call)
    refusals = [
        "i don't know", "não sei", "não tenho informações", "no information", 
        "cannot answer", "não há informações", "a resposta não está disponível",
        "não encontrei informações", "desculpe", "sinto muito"
    ]
    for r in refusals:
        if r in generation.lower():
             print("---DECISION: ANSWER IS REFUSAL---")
             return {"generation": generation, "is_refusal": True}
             
    print("---DECISION: ANSWER IS VALID---")
    return {"generation": generation, "is_refusal": False}

    print("---DECISION: ANSWER IS VALID---")
    return {"generation": generation, "is_refusal": False}

from core.tools.kiwix import KiwixClient

def offline_search(state: AgentState) -> Dict[str, Any]:
    """
    Search offline verification (Kiwix).
    """
    print("---OFFLINE SEARCH (Kiwix)---")
    question = state["question"]
    
    kiwix = KiwixClient()
    results = kiwix.search(question, num_results=2)
    
    documents = []
    if results:
        print(f"  📚 Found {len(results)} articles in Kiwix.")
        for r in results:
            # Fetch full content for the best result
            content = kiwix.get_page_content(r["url"])
            doc_str = f"Source: Kiwix (Offline)\nTitle: {r['title']}\nURL: {r['url']}\n\n{content}"
            documents.append(doc_str)
            print(f"  📄 Read article: {r['title']}")
    else:
        print("  ⚠️ No Kiwix results found.")
    
    retry_count = state.get("retry_count", 0) + 1
    return {"documents": documents, "question": question, "retry_count": retry_count}

from core.tools.searxng import SearXNGClient
from core.tools.scraper import PlaywrightScraper

def web_search(state: AgentState) -> Dict[str, Any]:
    """
    Fallback: Search via SearXNG, scrape via Playwright (Stealth), validate staleness, and auto-ingest.
    """
    print("---WEB SEARCH (SearXNG + Playwright)---")
    question = state["question"]
    
    searx = SearXNGClient()
    scraper = PlaywrightScraper()
    
    documents = []
    
    try:
        # 1. Search for URLs (Deep Search Strategy)
        print(f"  🔍 Querying SearXNG: {question}")
        
        # A. General Search
        results_gen = searx.search(question, num_results=3)
        
        # B. Targeted Search (Community/Tech)
        # Append site filters to finding discussions and code
        tech_query = f"{question} (site:reddit.com OR site:github.com OR site:stackoverflow.com OR site:ycombinator.com)"
        print(f"  🔍 Querying Specialized Sources: {tech_query}")
        results_tech = searx.search(tech_query, num_results=3)
        
        # Combine and Deduplicate by URL
        unique_urls = set()
        combined_results = []
        
        for r in results_gen + results_tech:
            if r.get("url") and r["url"] not in unique_urls:
                unique_urls.add(r["url"])
                combined_results.append(r)
        
        if combined_results:
            # Limit scraping to top 5
            for r in combined_results[:5]:
                url = r.get("url")
                
                # 2. Scrape Content (Stealth)
                print(f"  🕷️ Playwright Scraping: {url}")
                data = scraper.scrape(url)
                
                if data["status"] == "success":
                    if data["is_stale"]:
                        print(f"  ⚠️ Skipping stale content ({data['date']})")
                        continue
                        
                    # Format content
                    content = f"Source: {url}\nTitle: {data['title']}\nDate: {data['date']}\n\n{data['content']}"
                    documents.append(content)
                    
                    # 3. Auto-Ingestion
                    try:
                        emb = embedder.embedding(content)
                        if emb:
                            vs.add_text(content, emb, {"source": "web_search", "url": url, "date": data['date']})
                            print("  💾 Auto-ingested web content.")
                    except Exception as e:
                        print(f"  ⚠️ Ingestion failed: {e}")
                else:
                    print(f"  ❌ Scrape failed: {data.get('error')}")
                        
        else:
            print("  ⚠️ No SearXNG results found.")

    except Exception as e:
        print(f"  ❌ Web Search failed: {e}")
        
    # 4. Fallback: If no docs found, try Kiwix (Offline)
    if not documents:
        print("  ⚠️ Web search yielded no results. Trying Offline (Kiwix)...")
        try:
            from core.tools.kiwix import KiwixClient
            kiwix = KiwixClient()
            k_results = kiwix.search(question, num_results=2)
            if k_results:
                 for r in k_results:
                     content = kiwix.get_page_content(r["url"])
                     documents.append(f"Source: Kiwix (Offline)\nTitle: {r['title']}\nURL: {r['url']}\n\n{content}")
                     print(f"  📚 Found offline article: {r['title']}")
        except Exception as e:
            print(f"  ❌ Kiwix Fallback failed: {e}")
    
    retry_count = state.get("retry_count", 0) + 1
    return {"documents": documents, "question": question, "retry_count": retry_count}
